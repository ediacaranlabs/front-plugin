<script type="text/javascript">
	$.AppContext.onload(function()&#123;
		
		var $func = function({var})&#123;
			var out_      = [];
			
			out_.push($.AppContext.constants.OPEN_TAG_);
			out_.push("script type=");
			out_.push($.AppContext.constants.DOUBLE_QUOTE);
			out_.push("text/javascript");
			out_.push($.AppContext.constants.DOUBLE_QUOTE);
			out_.push("");
			out_.push($.AppContext.constants.END_TAG_);
			
			out_.push("var {var} = JSON.parse(");
			out_.push(JSON.stringify(JSON.stringify({var})));
			out_.push(");");

			out_.push($.AppContext.constants.OPEN_TAG_);
			out_.push("/script");
			out_.push($.AppContext.constants.END_TAG_);
            			
			{content}
			
			return out_.join("");
		&#125;;
		
		$.AppContext.dataTable.apply("{from}", $func);
	&#125;);
</script>
<span id="{from}_result">
	<div class="col-sm-12 col-md-12 col-lg-12 col-xl-12 pagination dataTablePagination">
	</div>
</span>